# Dorm Power Production Environment Configuration
# 服务器: 111.230.60.71
# 部署日期: 2026-03-16

# ============================================
# Server Configuration
# ============================================
SERVER_IP=111.230.60.71
SERVER_PORT=8000

# ============================================
# Database Configuration (PostgreSQL)
# ============================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=dorm_power
DB_USERNAME=dormpower
DB_PASSWORD=CHANGE_ME

# ============================================
# JWT Configuration
# 注意: 生产环境必须使用强密钥，至少256位
# ============================================
JWT_SECRET=CHANGE_ME
JWT_EXPIRATION=86400000

# ============================================
# MQTT Configuration
# ============================================
MQTT_ENABLED=true
MQTT_BROKER_URL=tcp://mosquitto:1883
MQTT_CLIENT_ID=dorm-power-backend-prod
MQTT_USERNAME=dormpower
MQTT_PASSWORD=CHANGE_ME
MQTT_TOPIC_PREFIX=dorm

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL_ROOT=warn
LOG_LEVEL_APP=info

# ============================================
# Spring Profile
# ============================================
SPRING_PROFILES_ACTIVE=prod

# ============================================
# Frontend Configuration
# ============================================
FRONTEND_PORT=3000
BACKEND_BASE_URL=http://111.230.60.71:8000

# ============================================
# Resource Limits (2核2G服务器优化)
# 总内存限制: 1500M (预留500M给系统)
# ============================================
BACKEND_MEMORY_LIMIT=600M
BACKEND_MEMORY_RESERVATION=400M
FRONTEND_MEMORY_LIMIT=300M
FRONTEND_MEMORY_RESERVATION=200M
POSTGRES_MEMORY_LIMIT=400M
POSTGRES_MEMORY_RESERVATION=200M
