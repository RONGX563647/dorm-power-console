# Dorm Power Backend Environment Configuration Example
# 复制此文件为 .env 并填写实际值

# ============================================
# Database Configuration
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dorm_power
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# ============================================
# JWT Configuration
# ============================================
JWT_SECRET=your-secret-key-must-be-at-least-256-bits-long-for-jwt
JWT_EXPIRATION=86400000

# ============================================
# MQTT Configuration
# ============================================
MQTT_ENABLED=true
MQTT_BROKER_URL=tcp://localhost:1883
MQTT_CLIENT_ID=dorm-power-backend
MQTT_USERNAME=admin
MQTT_PASSWORD=admin
MQTT_TOPIC_PREFIX=dorm

# ============================================
# Server Configuration
# ============================================
SERVER_PORT=8000

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL_ROOT=info
LOG_LEVEL_APP=debug
