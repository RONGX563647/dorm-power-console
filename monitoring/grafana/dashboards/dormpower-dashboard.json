{
  "dashboard": {
    "id": null,
    "title": "DormPower 系统监控面板",
    "tags": ["dormpower", "spring-boot"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 0,
    "refresh": "5s",
    "panels": [
      {
        "id": 1,
        "title": "API 请求 QPS",
        "type": "graph",
        "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "rate(dormpower_api_request_total[1m])",
            "legendFormat": "{{method}} {{uri}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          { "label": "QPS", "min": 0 },
          { "show": false }
        ]
      },
      {
        "id": 2,
        "title": "API 响应时间 (P99)",
        "type": "graph",
        "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "histogram_quantile(0.99, rate(dormpower_api_request_seconds_bucket[5m]))",
            "legendFormat": "{{method}} {{uri}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          { "label": "秒", "min": 0 },
          { "show": false }
        ]
      },
      {
        "id": 3,
        "title": "设备在线数",
        "type": "stat",
        "gridPos": { "x": 0, "y": 8, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "dormpower_device_online_total",
            "legendFormat": "在线设备",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "steps": [
                { "color": "red", "value": null },
                { "color": "yellow", "value": 50 },
                { "color": "green", "value": 100 }
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "WebSocket 连接数",
        "type": "stat",
        "gridPos": { "x": 6, "y": 8, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "dormpower_websocket_connections_total",
            "legendFormat": "连接数",
            "refId": "A"
          }
        ]
      },
      {
        "id": 5,
        "title": "缓存命中率",
        "type": "gauge",
        "gridPos": { "x": 12, "y": 8, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "dormpower_cache_hit_rate / 100",
            "legendFormat": "命中率",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 1,
            "unit": "percentunit"
          }
        }
      },
      {
        "id": 6,
        "title": "限流统计",
        "type": "graph",
        "gridPos": { "x": 18, "y": 8, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "rate(dormpower_rate_limit_rejected_total[1m])",
            "legendFormat": "拒绝 ({{limit_type}})",
            "refId": "A"
          },
          {
            "expr": "rate(dormpower_rate_limit_allowed_total[1m])",
            "legendFormat": "允许 ({{limit_type}})",
            "refId": "B"
          }
        ]
      },
      {
        "id": 7,
        "title": "JVM 内存使用率",
        "type": "graph",
        "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "dormpower_jvm_memory_usage_ratio",
            "legendFormat": "内存使用率",
            "refId": "A"
          }
        ],
        "yaxes": [
          { "label": "使用率", "min": 0, "max": 1 },
          { "show": false }
        ]
      },
      {
        "id": 8,
        "title": "活跃线程数",
        "type": "graph",
        "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "dormpower_threads_active_total",
            "legendFormat": "线程数",
            "refId": "A"
          }
        ]
      }
    ]
  }
}
