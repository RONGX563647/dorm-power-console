# Dorm Power Project Git Ignore
# 排除敏感文件和不需要版本控制的文件

# ============================================
# 环境变量文件（包含敏感信息）
# ============================================
.env
.env.local
.env.*.local
.env.production
.env.docker
.env.*
!.env.example
!.env.*.example

# ============================================
# 密钥和证书
# ============================================
*.pem
*.key
*.crt
*.p12
*.jks
*.keystore
*.truststore
nginx/ssl/*
!nginx/ssl/.gitkeep

# ============================================
# 日志文件
# ============================================
*.log
logs/
log/
nginx_logs/

# ============================================
# 数据库文件
# ============================================
*.db
*.sqlite
*.sqlite3
postgres_data/
*.sql
!src/main/resources/*.sql

# ============================================
# 备份文件
# ============================================
backup/
*.bak
*.backup

# ============================================
# IDE 和编辑器
# ============================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
*.iml
.classpath
.project
.settings/

# ============================================
# 构建输出
# ============================================
target/
build/
dist/
out/
*.jar
*.war
*.ear

# ============================================
# 依赖目录
# ============================================
node_modules/
.mvn/
.npm-cache/
package-lock.json
yarn.lock
pnpm-lock.yaml

# ============================================
# Docker 数据卷
# ============================================
mosquitto/data/
mosquitto/log/
*.pid

# ============================================
# 测试和临时文件
# ============================================
tmp/
temp/
*.tmp
*.temp
coverage/
.nyc_output/

# ============================================
# 前端特定
# ============================================
.next/
.vercel/
.turbo/
*.tsbuildinfo

# ============================================
# 后端特定
# ============================================
*.class
*.war
*.ear
hs_err_pid*
replay_pid*

# ============================================
# Python 特定
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
env.bak/
venv.bak/

# ============================================
# 其他
# ============================================
*.tgz
*.tar.gz
*.zip
*.rar
